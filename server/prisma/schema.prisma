generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
}

model Task {
  id                       String   @id @default(uuid())
  title                    String
  subtitle                 String[]
  duration_required        Int      // duration in seconds
  is_complete              Boolean  @default(false)
  completed_subtitle_count Int      @default(0) // raw count; % = (completed_subtitle_count / subtitle.length) * 100
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  userId String
}
